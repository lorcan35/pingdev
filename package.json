{
  "name": "pingos",
  "version": "0.1.0",
  "private": true,
  "description": "PingOS — an ahead-of-time web-to-API compiler. The operating system for the web.",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf packages/*/dist"
  },
  "author": "PingDev",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "@types/node": "^25.2.3"
  }
}
